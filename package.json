{
  "name": "always-here",
  "version": "1.3.1",
  "description": "一款包含桌面宠物、时钟、便签、秒表和打工倒计时的 Electron 桌面陪伴工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "pack": "npx asar pack src dist/app.asar",
    "test": "node --test"
  },
  "keywords": [
    "electron",
    "desktop-widget",
    "desktop-pet",
    "productivity",
    "windows"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/PhyQxx/always-here.git"
  },
  "bugs": {
    "url": "https://github.com/PhyQxx/always-here/issues"
  },
  "homepage": "https://github.com/PhyQxx/always-here#readme",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.always-here.app",
    "productName": "Always Here",
    "publish": [
      {
        "provider": "generic",
        "url": "https://ftp.pnkx.top:8/ftp/always-here/"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  }
}
