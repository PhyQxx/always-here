{
  "name": "always-here",
  "version": "1.1.0",
  "description": "一款包含桌面宠物、时钟、便签、秒表和打工倒计时的 Electron 桌面陪伴工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "pack": "npx asar pack src dist/app.asar",
    "test": "node --test"
  },
  "keywords": [
    "electron",
    "desktop-widget",
    "desktop-pet",
    "productivity",
    "windows"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/PhyQxx/always-here.git"
  },
  "bugs": {
    "url": "https://github.com/PhyQxx/always-here/issues"
  },
  "homepage": "https://github.com/PhyQxx/always-here#readme",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.always-here.app",
    "productName": "Always Here",
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
